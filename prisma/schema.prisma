datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Rol {
  id_rol      Int       @id @default(autoincrement())
  nombre_rol  String
  descripcion String
  usuarios    Usuario[]
}

model Division {
  id_division     Int    @id @default(autoincrement())
  nombre_division String
  siglas          String

  carreras Carrera[]
  usuarios Usuario[]
}

model Carrera {
  id_carrera      Int     @id @default(autoincrement())
  nombre_carrera  String
  modalidad       String?
  id_division     Int

  division Division  @relation(fields: [id_division], references: [id_division])
  usuarios Usuario[]
}

model ListaEspera {
  id_lista       Int      @id @default(autoincrement())
  correo         String   @unique
  fecha_registro DateTime @default(now())
  estado         String   @default("pendiente")
}

model Usuario {
  id_usuario       Int     @id @default(autoincrement())
  nombre           String
  apellido_paterno String
  apellido_materno String
  correo           String  @unique
  contrasena       String
  id_carrera       Int?
  id_division      Int?
  cuatrimestre     Int     @default(1)
  id_rol           Int
  activo           Boolean @default(true)

  rol      Rol      @relation(fields: [id_rol], references: [id_rol])
  carrera  Carrera?  @relation(fields: [id_carrera], references: [id_carrera])
  division Division? @relation(fields: [id_division], references: [id_division])

  periodosEntrenador     Periodo[]     @relation("PeriodoEntrenador")
  inscripciones          Inscripcion[] @relation("UsuarioInscripciones")
  inscripcionesAprobadas Inscripcion[] @relation("UsuarioAprobador")
  asistencias            Asistencia[]  @relation("AsistenciaUsuario")
  asistenciasRegistradas Asistencia[]  @relation("AsistenciaRegistrador")

  asistenciasHistorico AsistenciaHistorico[]
  propuestas           Propuesta[]
}

model Periodo {
  id_periodo                Int      @id @default(autoincrement())
  nombre_periodo            String
  fecha_inicio_inscripcion DateTime
  fecha_fin_inscripcion     DateTime
  fecha_inicio_actividades DateTime
  fecha_fin_periodo         DateTime
  estado                    String
  id_entrenador             Int

  entrenador Usuario @relation("PeriodoEntrenador", fields: [id_entrenador], references: [id_usuario])

  horarios      Horario[]
  inscripciones Inscripcion[]
}

model Horario {
  id_horario       Int      @id @default(autoincrement())
  id_periodo       Int
  hora_inicio      String   
  hora_fin         String   
  tipo_actividad   String?
  capacidad_maxima Int

  periodo Periodo @relation(fields: [id_periodo], references: [id_periodo])

  horarioDias   HorarioDia[]
  inscripciones Inscripcion[]
  asistencias   Asistencia[]
  propuestas    Propuesta[]
}

model Dia {
  id_dia Int    @id @default(autoincrement())
  nombre String

  horarioDias       HorarioDia[]
  inscripcionesDias InscripcionDia[]
  propuestasDias    PropuestaDia[]
}

model HorarioDia {
  id_horario_dia Int @id @default(autoincrement())
  id_horario     Int
  id_dia         Int

  horario Horario @relation(fields: [id_horario], references: [id_horario])
  dia     Dia     @relation(fields: [id_dia], references: [id_dia])

  @@unique([id_horario, id_dia])
}

model Inscripcion {
  id_inscripcion    Int       @id @default(autoincrement())
  id_usuario        Int
  id_horario        Int
  id_periodo        Int
  fecha_inscripcion DateTime  @default(now())
  estado            String
  prioridad         String
  id_aprobador      Int?
  fecha_decision    DateTime?

  usuario   Usuario  @relation("UsuarioInscripciones", fields: [id_usuario], references: [id_usuario])
  horario   Horario  @relation(fields: [id_horario], references: [id_horario])
  periodo   Periodo  @relation(fields: [id_periodo], references: [id_periodo])
  aprobador Usuario? @relation("UsuarioAprobador", fields: [id_aprobador], references: [id_usuario])

  asistencias       Asistencia[]
  diasSeleccionados InscripcionDia[]
  propuestas        Propuesta[]
}

model InscripcionDia {
  id_inscripcion_dia Int @id @default(autoincrement())
  id_inscripcion     Int
  id_dia             Int

  inscripcion Inscripcion @relation(fields: [id_inscripcion], references: [id_inscripcion])
  dia         Dia         @relation(fields: [id_dia], references: [id_dia])
}

model Asistencia {
  id_asistencia     Int      @id @default(autoincrement())
  id_usuario         Int
  id_inscripcion     Int
  id_horario         Int
  fecha              DateTime
  asistio            Boolean
  id_registrado_por Int

  usuario     Usuario     @relation("AsistenciaUsuario", fields: [id_usuario], references: [id_usuario])
  registrador Usuario     @relation("AsistenciaRegistrador", fields: [id_registrado_por], references: [id_usuario])
  inscripcion Inscripcion @relation(fields: [id_inscripcion], references: [id_inscripcion])
  horario     Horario     @relation(fields: [id_horario], references: [id_horario])
}

model AsistenciaHistorico {
  id_historico   Int      @id @default(autoincrement())
  nombre_archivo String
  ruta_archivo   String
  hash_archivo   String   @unique
  fecha_lista    DateTime
  fecha_subida   DateTime @default(now())
  id_usuario     Int

  usuario Usuario @relation(fields: [id_usuario], references: [id_usuario])
}

model Propuesta {
  id_propuesta Int @id @default(autoincrement())

  id_inscripcion Int
  id_horario     Int
  id_usuario     Int

  estado          String    @default("pendiente") 
  fecha_envio     DateTime  @default(now())
  fecha_respuesta DateTime?

  inscripcion Inscripcion @relation(fields: [id_inscripcion], references: [id_inscripcion])
  horario     Horario     @relation(fields: [id_horario], references: [id_horario])
  usuario     Usuario     @relation(fields: [id_usuario], references: [id_usuario])

  dias PropuestaDia[]
  @@map("propuesta")
}

model PropuestaDia {
  id_propuesta_dia Int @id @default(autoincrement())

  id_propuesta Int
  id_dia       Int

  propuesta Propuesta @relation(fields: [id_propuesta], references: [id_propuesta])
  dia       Dia       @relation(fields: [id_dia], references: [id_dia])
  @@map("propuesta_dia")
}